# App web (Docker) — compartilhe http://SEU_IP:APP_PORT com testadores na rede
APP_PORT=5173

# Deixe em branco no Docker (padrão: /srv-gerenciaracademia via nginx). Só altere para rebuild com URL absoluta.
# VITE_API_URL=/srv-gerenciaracademia

# PostgreSQL (5435 no host — 5432-5434 costumam estar ocupados por outros containers)
POSTGRES_HOST_PORT=5435
POSTGRES_PASSWORD=academia_dev_secret

# JWT (mínimo 32 caracteres em produção)
JWT_SECRET=change-me-in-production-min-32-chars!!

# Usuário master inicial (criado automaticamente no profile docker)
APP_MASTER_CPF=00000000191
APP_MASTER_PASSWORD=Master@2024!
