# App web (Docker)
APP_PORT=5173

# Tunel publico sobe automaticamente com docker compose up (logs: docker compose logs tunnel)
# Para desativar o tunel: docker compose up -d postgres backend frontend

# Opcional: URL fixa com ngrok — docker compose -f docker-compose.yml -f infra/docker/docker-compose.ngrok.yml up -d --build
# NGROK_AUTHTOKEN=

# Deixe em branco no Docker (padrão: /srv-gerenciaracademia via nginx). Só altere para rebuild com URL absoluta.
# VITE_API_URL=/srv-gerenciaracademia

# PostgreSQL (5435 no host — 5432-5434 costumam estar ocupados por outros containers)
POSTGRES_HOST_PORT=5435
POSTGRES_PASSWORD=academia_dev_secret

# JWT (mínimo 32 caracteres em produção)
JWT_SECRET=change-me-in-production-min-32-chars!!

# Usuário master inicial (criado automaticamente no profile docker)
APP_MASTER_CPF=00000000191
APP_MASTER_PASSWORD=Master@2024!

# Performance Docker (dev/teste)
BACKEND_MEM_LIMIT=768m
BACKEND_CPUS=1.5
POSTGRES_MEM_LIMIT=384m
POSTGRES_CPUS=0.5
# JAVA_OPTS=-XX:+UseContainerSupport -Xms256m -Xmx512m -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError

# Seeds: true em dev; false em produção (use infra/docker/docker-compose.prod.yml)
APP_SEED_DEMO=true
APP_BOOTSTRAP_MASTER=true

# Backup PostgreSQL (scripts/backup-postgres.ps1)
BACKUP_RETENTION=14
BACKUP_WEEKLY_DAYS=7
# SPRING_PROFILES_ACTIVE=docker
# Produção: docker compose -f docker-compose.yml -f infra/docker/docker-compose.prod.yml up -d --build
# VPS app + DB separados: ver docs/DEPLOY_VPS.md e infra/docker/docker-compose.vps-app.yml

# Site institucional — contato comercial (frontend)
# VITE_CONTATO_EMAIL=comercial@turma360.com.br
# VITE_CONTATO_WHATSAPP=5511934200782
# VITE_CONTATO_WHATSAPP_LABEL=(11) 93420-0782

# Integrações (modo local = true sem chaves; false em produção com credenciais)
APP_INTEGRACOES_MODO_LOCAL=true
BREVO_ENABLED=false
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=noreply@seudominio.com
TWILIO_ENABLED=false
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ASAAS_ENABLED=false
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_TOKEN=
# ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# VPS banco remoto (overlay vps-app)
# DB_HOST=10.0.0.2
# DB_PORT=5432
# POSTGRES_USER=academia_app
